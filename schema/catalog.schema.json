{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://provisioner-catalog.startcloud.com/schema/catalog.schema.json",
    "title": "STARTcloud Provisioner Catalog (catalog.json)",
    "description": "The wire contract consumed by hyperweaver-agent and zoneweaver-agent. catalog.json is a build artifact generated by the data job — never committed. format_version bumps only on breaking changes to this shape and is separate from the repository's own release version.",
    "type": "object",
    "additionalProperties": false,
    "required": ["name", "format_version", "updated", "provisioners"],
    "properties": {
        "name": {
            "type": "string",
            "minLength": 1
        },
        "format_version": {
            "const": 1
        },
        "updated": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the data-job run that generated this document"
        },
        "provisioners": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "repo", "description", "versions"],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Family slug — the name: from the package's provisioner.yml, also the archive filename prefix",
                        "pattern": "^[A-Za-z0-9._-]+$"
                    },
                    "repo": {
                        "type": "string",
                        "description": "GitHub repository the family's releases come from, as owner/name",
                        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?/[A-Za-z0-9._-]+$"
                    },
                    "description": {
                        "type": "string",
                        "description": "Parsed from the provisioner.yml inside the latest release's artifact — never from the GitHub repo description"
                    },
                    "versions": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": ["version", "artifacts"],
                            "properties": {
                                "version": {
                                    "type": "string",
                                    "description": "Semantic version, sourced from the versioned asset filename and verified against the packaged provisioner.yml",
                                    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+[0-9A-Za-z.+-]*$"
                                },
                                "artifacts": {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": {
                                        "type": "object",
                                        "additionalProperties": false,
                                        "required": ["url", "checksum_type", "checksum"],
                                        "properties": {
                                            "url": {
                                                "type": "string",
                                                "description": "VERSIONED release asset URL (immutable) — never the mutable <name>.tar.gz latest alias",
                                                "pattern": "^https://"
                                            },
                                            "checksum_type": {
                                                "const": "sha256"
                                            },
                                            "checksum": {
                                                "type": "string",
                                                "description": "sha256 of the tar.gz, computed by the data job; consumers verify after download",
                                                "pattern": "^[a-f0-9]{64}$"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
